.time-slots-card {
  margin-bottom: 20rpx;
}

.time-slot-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.time-slot-item:last-child {
  border-bottom: none;
}

.slot-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.slot-time {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.slot-checkbox {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.checkbox-label {
  font-size: 26rpx;
  color: #666666;
}

.progress-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 26rpx;
}

.btn-wrapper {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}
