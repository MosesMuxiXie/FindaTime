<view class="container">
  <view class="section-title">选择你的时间段</view>
  
  <!-- 时间段2（选填） -->
  <view class="card">
    <view class="section-subtitle">时间段2（选填）</view>
    
    <view class="form-item">
      <text class="form-label">选择日期</text>
      <picker 
        mode="multiSelector" 
        range="{{dateRange}}" 
        range-key="{{'label'}}"
        value="{{date2Index}}"
        bindchange="onDate2Change"
      >
        <view class="form-input picker-input">
          <text wx:if="{{selectedDate2}}">{{selectedDate2}}</text>
          <text wx:else class="placeholder">选择年—月—日</text>
        </view>
      </picker>
    </view>

    <view class="time-row">
      <view class="time-col">
        <text class="form-label">开始时间</text>
        <picker 
          mode="time" 
          value="{{startTime2}}" 
          bindchange="onStartTime2Change"
        >
          <view class="form-input picker-input">
            <text wx:if="{{startTime2}}">{{startTime2}}</text>
            <text wx:else class="placeholder">选择</text>
          </view>
        </picker>
      </view>
      <view class="time-col">
        <text class="form-label">结束时间</text>
        <picker 
          mode="time" 
          value="{{endTime2}}" 
          bindchange="onEndTime2Change"
        >
          <view class="form-input picker-input">
            <text wx:if="{{endTime2}}">{{endTime2}}</text>
            <text wx:else class="placeholder">选择</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

